# --- PostgreSQL ---
POSTGRES_USER=baikal_user
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ
POSTGRES_DB=baikal_buuzy

# --- Backend ---
PORT=8080
DATABASE_URL=postgres://baikal_user:ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ@db:5432/baikal_buuzy?sslmode=disable
JWT_SECRET=ЗАМЕНИТЕ_НА_ДЛИННЫЙ_СЛУЧАЙНЫЙ_СЕКРЕТ_МИНИМУМ_64_СИМВОЛА
